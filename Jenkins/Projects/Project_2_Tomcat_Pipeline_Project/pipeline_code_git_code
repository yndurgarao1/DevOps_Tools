******************************Git clone with war file copying to Tomcat Server *******************
pipeline {
    agent any 
        stages {
            stage(Workspace_Clean) {
                steps {
                    sh 'rm -rf java_project'
                }
            }
            stage(Git_Clone) {
                steps {
                    sh 'git clone https://github.com/yndrao/java_project.git'
                }
            }
			stage(Maven_Build) {
			    steps {
			        dir('java_project') {
			            sh 'mvn clean'
			            sh 'mvn package'
			        }
			    }
			}
			stage(Tomcat) {
				steps {
					sshagent(['tokyo_region_key']) {
					    sh """
					    scp -o StrictHostKeyChecking=no /var/lib/jenkins/workspace/Project_1/java_project/target/*.war ec2-user@10.20.25.200:/apache-tomcat-9.0.115/webapps
                        """
					}
					}        
			}
        }
}
