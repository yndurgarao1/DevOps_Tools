*****************Git Clone with Maven Commands*****************************************************
pipeline {
    agent any 
        stages {
            stage(Workspace_Clean) {
                steps {
                    sh 'rm -rf java_project'
                }
            }
            stage(Git_Clone) {
                steps {
                    sh 'git clone https://github.com/yndrao/java_project.git'
                }
            }
			stage(Maven_Build) {
				steps {
					sh 'cd java_project'
					sh 'mvn clean'
					sh 'mvn package'
				}
			}
        }
}
